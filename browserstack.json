{
  "auth": {
    "username": "${BROWSERSTACK_USERNAME}",
    "access_key": "${BROWSERSTACK_ACCESS_KEY}"
  },
  "browsers": [{
          "browser": "chrome",
          "os": "Windows 10",
          "versions": ["latest"]
        }],
  "run_settings": {
    "cypress_config_file": "./cypress.config.js",
    "project_name": "Prosight Automation",
    "build_name": "QA Build 1",
